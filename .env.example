# 飞书配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BOT_NAME=机器人名字
FEISHU_MASTER_NAME=你的名字

# Cursor配置
CURSOR_API_KEY=your_cursor_api_key_here
CURSOR_GITHUB_REPO=https://github.com/your_github_repository_here
CURSOR_GITHUB_REF=main
CURSOR_MODEL=gemini-3-flash

# 可选配置
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# 群聊消息模式：all=所有消息都转发 | mention_only=只有@机器人才转发
GROUP_CHAT_MODE=mention_only
